# 熙心健康体检平台环境变量配置
# 复制此文件为 .env 并填入实际值

# 数据库配置
DB_URL=jdbc:mysql://127.0.0.1:3306/xixin_health?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai&useSSL=false&allowPublicKeyRetrieval=true
DB_USERNAME=root
DB_PASSWORD=your_password_here

# JWT 配置
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRE_SECONDS=7200

# 服务器配置
SERVER_PORT=18080

# Spring Profile
SPRING_PROFILES_ACTIVE=dev
