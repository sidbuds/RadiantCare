@startuml
skinparam defaultFontName Microsoft YaHei
skinparam defaultFontSize 12
skinparam rectangle {
  BackgroundColor<<green>> #E8F5E9
  BorderColor<<green>> #4CAF50
  BackgroundColor<<orange>> #FFF3E0
  BorderColor<<orange>> #FF9800
  BackgroundColor<<blue>> #E3F2FD
  BorderColor<<blue>> #2196F3
  BackgroundColor<<pink>> #FCE4EC
  BorderColor<<pink>> #E91E63
  BackgroundColor<<purple>> #F3E5F5
  BorderColor<<purple>> #9C27B0
  BackgroundColor<<deep>> #EDE7F6
  BorderColor<<deep>> #673AB7
  BackgroundColor<<red>> #FFCDD2
  BorderColor<<red>> #F44336
  BackgroundColor<<darkgreen>> #C8E6C9
  BorderColor<<darkgreen>> #4CAF50
  BackgroundColor<<white>> #FFFFFF
  BorderColor<<white>> #999999
}

title 熙心健康体检平台系统结构图

rectangle "前端UI层" <<green>> {
  rectangle "Vue 3" <<white>>
  rectangle "TypeScript" <<white>>
  rectangle "Element Plus" <<white>>
  rectangle "Axios + Pinia" <<white>>
}

rectangle "展示层" <<orange>> {
  rectangle "游客端: 首页/套餐/中心/流程/FAQ" <<white>>
  rectangle "用户端: 预约/订单/导检/报告/对比/咨询" <<white>>
  rectangle "医生端: 待检/录入/审核/咨询/异常分析/工作量" <<white>>
  rectangle "运营端: 套餐/排班/预约/订单/退款/看板" <<white>>
  rectangle "管理端: 任务/报告/咨询/医生分析" <<white>>
}

rectangle "业务层" <<blue>> {
  rectangle "业务模块" <<pink>> {
    rectangle "认证" <<white>>
    rectangle "用户管理" <<white>>
    rectangle "预约" <<white>>
    rectangle "订单" <<white>>
    rectangle "体检执行" <<white>>
    rectangle "报告管理" <<white>>
    rectangle "咨询医生" <<white>>
    rectangle "历年对比" <<white>>
    rectangle "健康建议" <<white>>
    rectangle "套餐管理(可裁剪)" <<white>>
    rectangle "运营分析(可裁剪)" <<white>>
    rectangle "质控管理(可裁剪)" <<white>>
  }
  rectangle "基础组件" <<purple>> {
    rectangle "菜单管理" <<white>>
    rectangle "数据字典" <<white>>
    rectangle "系统参数" <<white>>
    rectangle "定时任务" <<white>>
    rectangle "消息通知" <<white>>
    rectangle "文件上传" <<white>>
  }
}

rectangle "数据层" <<green>> {
  rectangle "Security" <<white>>
  rectangle "JWT认证" <<white>>
  rectangle "RBAC权限" <<white>>
  rectangle "MyBatis-Plus" <<white>>
  rectangle "PageHelper" <<white>>
  rectangle "BCrypt加密" <<white>>
}

rectangle "数据库" <<deep>> {
  rectangle "MySQL 8.0" <<white>>
  rectangle "Redis 7" <<white>>
  rectangle "文件存储" <<white>>
}

rectangle "运行环境" <<blue>> {
  rectangle "Docker容器" <<white>>
  rectangle "本地Java运行" <<white>>
  rectangle "Nginx部署" <<white>>
}

rectangle "日志记录" <<red>>
rectangle "权限控制" <<darkgreen>>

@enduml
